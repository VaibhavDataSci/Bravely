# Server Configuration
PORT=5000

# Database — replace with your actual connection string
# For local dev without Postgres, leave blank (DB calls will fail gracefully)
POSTGRES_URL=

# Auth
JWT_SECRET=bravely-dev-secret-change-in-production

# Redis — leave blank if not running Redis locally (BullMQ queue won't work but HTTP routes will)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins the browser is allowed to call from
ALLOWED_ORIGINS=http://localhost:3000
